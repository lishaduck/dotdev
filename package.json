{
  "name": "elm-pages-app",
  "type": "module",
  "scripts": {
    "dev": "INCLUDE_DRAFTS=true elm-pages dev",
    "build": "elm-pages build --strict",
    "format:elm": "lamdera format app/ review/ script/ src/ --yes",
    "format:elm:check": "lamdera format app/ review/ script/ src/ --validate",
    "format:prettier": "prettier . --write --experimental-cli",
    "format:prettier:check": "prettier . --check --experimental-cli",
    "typecheck": "tsc --noEmit",
    "lint:markdown": "markdownlint-cli2 '**/*.md' '#node_modules'"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "elm": "0.19.1-6",
    "elm-codegen": "^0.6.3",
    "elm-format": "^0.8.8",
    "elm-json": "npm:@lydell/elm-json@0.2.13-1",
    "elm-optimize-level-2": "^0.3.5",
    "elm-pages": "^3.3.4",
    "elm-review": "^2.13.5",
    "elm-tailwind-classes": "^0.6.2",
    "lamdera": "0.19.1-1.4.0",
    "markdownlint": "^0.40.0",
    "markdownlint-cli2": "^0.22.0",
    "prettier": "^3.8.3",
    "typescript": "6.0.3",
    "vite": "^7.3.2"
  },
  "dependencies": {
    "@netlify/functions": "^5.2.0",
    "tailwindcss": "^4.2.2"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
